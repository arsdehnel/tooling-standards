{
	"$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
	"files": {
		"includes": [
			"**",
			"!coverage",
			"!package.json",
			"!src/templates",
			"!worker-configuration.d.ts",
			"!**/.terraform",
			"!**/.wrangler",
			"!**/dist",
			"!**/node_modules",
			"!*.css",
			"!*.less"
		]
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "tab",
		"indentWidth": 4,
		"lineWidth": 130
	},
	"javascript": {
		"formatter": {
			"arrowParentheses": "asNeeded",
			"quoteStyle": "single",
			"semicolons": "always",
			"trailingCommas": "all"
		},
		"jsxRuntime": "transparent"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	}
}
