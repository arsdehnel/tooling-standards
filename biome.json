{
	"$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
	"css": {
		"formatter": {
			"enabled": true,
			"indentStyle": "tab"
		}
	},
	"files": {
		"includes": ["**", "!coverage", "!**/node_modules", "!**/dist", "!src/templates", "!package.json", "!*.css", "!*.less"]
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 130
	},
	"javascript": {
		"formatter": {
			"arrowParentheses": "asNeeded",
			"quoteStyle": "single",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	}
}
