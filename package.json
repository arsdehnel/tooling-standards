{
	"name": "tooling-standards",
	"version": "1.0.0",
	"description": "CLI tool to sync and manage tooling standards across projects",
	"main": "index.js",
	"type": "module",
	"bin": {
		"tooling": "./src/cli.js"
	},
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"dev": "node src/cli.js",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"check": "biome check --write .",
		"type-check": "tsc --noEmit",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,ts,json}": [
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.8.0",
	"dependencies": {
		"@inquirer/prompts": "^8.4.1",
		"@octokit/rest": "^22.0.1",
		"chalk": "^5.6.2",
		"diff": "^8.0.4",
		"inquirer": "^13.4.1",
		"yargs": "^18.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"semantic-release": "^25.0.3",
		"typescript": "^6.0.2",
		"vitest": "^4.1.4"
	}
}
