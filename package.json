{
  "name": "tooling-standards",
  "version": "1.0.0",
  "description": "CLI tool to sync and manage tooling standards across projects",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.js",
  "bin": {
    "tooling": "./src/cli.js"
  },
  "scripts": {
    "check": "biome check --write .",
    "dev": "node src/cli.js",
    "format": "biome format --write . && prettier --write \"**/*.{css,less}\" package.json",
    "format:prettier": "prettier --write \"**/*.{css,less}\" package.json",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "prepare": "husky",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.json": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "package.json": [
      "prettier --write"
    ],
    "*.{css,less}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "@octokit/rest": "^22.0.1",
    "chalk": "^5.6.2",
    "diff": "^8.0.4",
    "inquirer": "^13.4.1",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "prettier-plugin-packagejson": "^3.0.2",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.8.0"
}
